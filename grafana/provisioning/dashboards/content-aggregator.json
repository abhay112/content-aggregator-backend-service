{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": 1,
  "links": [],
  "liveNow": false,
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["content-aggregator"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Content Aggregator — Full Observability",
  "uid": "jr-dev-monitor",
  "version": 2,

  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Prometheus",
        "query": "prometheus",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "current": { "selected": true, "text": "Prometheus", "value": "Prometheus" },
        "options": []
      },
      {
        "name": "loki_datasource",
        "type": "datasource",
        "label": "Loki",
        "query": "loki",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "current": {},
        "options": []
      },
      {
        "name": "route",
        "type": "query",
        "label": "Route",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(http_requests_total{app=\"content-aggregator\"}, route)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "current": {},
        "options": []
      }
    ]
  },

  "panels": [

    {
      "id": 1, "type": "row",
      "title": "SECTION 1: API OVERVIEW",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },

    {
      "id": 2, "type": "stat",
      "title": "Total API Calls (5m)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "options": {
        "colorMode": "value", "graphMode": "area",
        "justifyMode": "auto", "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "floor(sum(increase(http_requests_total{app=\"content-aggregator\"}[5m])) or vector(0))",
          "instant": true, "refId": "A"
        }
      ]
    },

    {
      "id": 3, "type": "stat",
      "title": "Failed API Calls (5m)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "options": {
        "colorMode": "value", "graphMode": "area",
        "justifyMode": "auto", "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "floor(sum(increase(http_requests_total{app=\"content-aggregator\", status_code=~\"4..|5..\"}[5m])) or vector(0))",
          "instant": true, "refId": "A"
        }
      ]
    },

    {
      "id": 4, "type": "gauge",
      "title": "Success Rate (%)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "options": {
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 100, "min": 0,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 98 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(\n  (sum(increase(http_requests_total{app=\"content-aggregator\", status_code!~\"4..|5..\"}[5m])) or vector(0))\n  /\n  (sum(increase(http_requests_total{app=\"content-aggregator\"}[5m])) or vector(1))\n) * 100",
          "instant": true, "refId": "A"
        }
      ]
    },

    {
      "id": 5, "type": "timeseries",
      "title": "Avg Response Time (ms)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ms",
          "custom": {
            "drawStyle": "line", "lineInterpolation": "smooth",
            "lineWidth": 2, "fillOpacity": 10,
            "showPoints": "never", "spanNulls": true
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(http_request_duration_seconds_sum{app=\"content-aggregator\"}[5m]) / rate(http_request_duration_seconds_count{app=\"content-aggregator\"}[5m]) * 1000",
          "legendFormat": "avg latency", "refId": "A"
        }
      ]
    },

    {
      "id": 20, "type": "row",
      "title": "SECTION 2: API FAILURE DEBUG",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "panels": []
    },

    {
      "id": 21, "type": "table",
      "title": "Failed Endpoints",
      "description": "Use the Route dropdown at the top to filter by any route",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "options": {
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Value" }]
      },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "displayMode": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Error Count" },
              {
                "id": "custom.displayMode", "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "red", "value": 1 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sort_desc(sum by (route, status_code, method) (increase(http_requests_total{app=\"content-aggregator\", status_code=~\"4..|5..\", route=~\"${route}\"}[5m])))",
          "instant": true,
          "legendFormat": "{{method}} {{route}} → {{status_code}}",
          "refId": "A",
          "format": "table"
        }
      ]
    },

    {
      "id": 22, "type": "table",
      "title": "Requests by Endpoint",
      "description": "Use the Route dropdown at the top to filter",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "options": {
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Value" }]
      },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "displayMode": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [{ "id": "displayName", "value": "Request Count" }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sort_desc(sum by (route, method, status_code) (increase(http_requests_total{app=\"content-aggregator\", route=~\"${route}\"}[5m])))",
          "instant": true,
          "legendFormat": "{{method}} {{route}} {{status_code}}",
          "refId": "A",
          "format": "table"
        }
      ]
    },

    {
      "id": 23, "type": "logs",
      "title": "Error Logs",
      "description": "Live error/warn log lines from the application",
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${loki_datasource}" },
          "expr": "{app=\"content-aggregator\"} | json | level=~\"error|warn\" | line_format \"[{{.level}}] {{.msg}}\"",
          "refId": "A"
        }
      ]
    },

    {
      "id": 30, "type": "row",
      "title": "SECTION 3: CRON JOB MONITORING",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "panels": []
    },

    {
      "id": 31, "type": "stat",
      "title": "Last Cron Run Time",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 17 },
      "options": {
        "colorMode": "value", "graphMode": "none",
        "justifyMode": "auto", "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "dateTimeAsLocal",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "cron_job_last_run_timestamp * 1000",
          "instant": true, "refId": "A"
        }
      ]
    },

    {
      "id": 32, "type": "stat",
      "title": "Cron Failure Rate (%)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 17 },
      "options": {
        "colorMode": "value", "graphMode": "none",
        "justifyMode": "auto", "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "(\n  (sum(increase(cron_job_runs_total{status=\"failure\"}[24h])) or vector(0))\n  /\n  (sum(increase(cron_job_runs_total[24h])) or vector(1))\n) * 100",
          "instant": true, "refId": "A"
        }
      ]
    },

    {
      "id": 33, "type": "timeseries",
      "title": "Articles Fetched by Cron",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 17 },
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "lineWidth": 1, "showPoints": "never" }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(articles_fetched_total[1h])) by (source)",
          "legendFormat": "{{source}}", "refId": "A"
        }
      ]
    },

    {
      "id": 34, "type": "logs",
      "title": "Cron Job Logs",
      "description": "All cron and fetcher log lines in real-time",
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${loki_datasource}" },
          "expr": "{app=\"content-aggregator\"} | json | msg=~\".*\\\\[Cron\\\\].*|.*\\\\[Fetcher\\\\].*|.*\\\\[Cleanup\\\\].*\"",
          "refId": "A"
        }
      ]
    },

    {
      "id": 35, "type": "timeseries",
      "title": "Cron Success vs Failure (24h)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars", "fillOpacity": 80,
            "lineWidth": 1, "showPoints": "never",
            "stacking": { "group": "A", "mode": "normal" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "success" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "failure" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(increase(cron_job_runs_total[24h])) by (status)",
          "legendFormat": "{{status}}", "refId": "A"
        }
      ]
    },

    {
      "id": 40, "type": "row",
      "title": "SECTION 4: SOURCE HEALTH",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "panels": []
    },

    {
      "id": 41, "type": "timeseries",
      "title": "Per-Source Fetch Duration (seconds)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "rate(source_fetch_duration_seconds_sum{status=\"success\"}[15m]) / rate(source_fetch_duration_seconds_count{status=\"success\"}[15m])",
          "legendFormat": "{{source}}", "refId": "A"
        }
      ]
    },

    {
      "id": 42, "type": "timeseries",
      "title": "Rate Limit Hits by Source",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars", "fillOpacity": 80,
            "lineWidth": 1, "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "increase(rate_limit_hits_total[1h])",
          "legendFormat": "{{source}}", "refId": "A"
        }
      ]
    }

  ]
}
